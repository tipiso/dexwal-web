---
import { getTranslations } from "@src/locale/getTranslations";
import { AppLangEnum } from "@src/lib/types";

const locale = Astro.currentLocale;
const t = getTranslations(locale);

const site = Astro.site ?? "https://dexwalppoz.com";
const supportedLocales: AppLangEnum[] = [
  AppLangEnum.PL,
  AppLangEnum.EN,
  AppLangEnum.CS,
  AppLangEnum.ES,
];
const defaultLocale = AppLangEnum.PL;

// Astro i18n routes:
// - default locale is *not* prefixed (`prefixDefaultLocale: false`)
// - other locales are prefixed (`/en/...`, `/cs/...`, ...)
const getPathWithoutLocalePrefix = (pathname: string) => {
  const parts = pathname.split("/");
  const maybeLocale = parts[1];
  const hasLocalePrefix = supportedLocales.includes(maybeLocale as AppLangEnum);
  const strippedParts = hasLocalePrefix ? parts.slice(2) : parts.slice(1);
  const strippedPath = `/${strippedParts.join("/")}`;
  return strippedPath === "" ? "/" : strippedPath;
};

const pathWithoutLocale = getPathWithoutLocalePrefix(Astro.url.pathname);
const isProductPage = pathWithoutLocale.startsWith("/products/");

const buildUrlForLocale = (targetLocale: AppLangEnum) => {
  // `pathWithoutLocale` already starts with `/`.
  if (targetLocale === defaultLocale)
    return new URL(pathWithoutLocale, site).toString();
  // Ensure homepage stays `/en/` (not `/en//`).
  if (pathWithoutLocale === "/")
    return new URL(`/${targetLocale}/`, site).toString();
  return new URL(`/${targetLocale}${pathWithoutLocale}`, site).toString();
};
---

<head>
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta name="description" content={t.meta.description} />
  <!-- Multilingual SEO -->
  {
    /*
    Page-specific hreflang for static pages.
    Product pages require mapping product IDs across languages (done in step 2),
    so we omit hreflang there for now to avoid incorrect duplicates.
  */
  }
  {
    !isProductPage &&
      supportedLocales.map((locale) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={buildUrlForLocale(locale)}
        />
      ))
  }

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <!-- PWA / Apple -->
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#c92200" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <!-- Open Graph -->
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:url" content="https://dexwalppoz.com/" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://dexwalppoz.com/og-image.png" />
  <meta property="og:locale" content={locale} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.description} />
  <meta name="twitter:image" content="https://dexwalppoz.com/og-image.png" />
</head>
