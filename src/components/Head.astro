---
import { getTranslations } from "@src/locale/getTranslations";
import { AppLangEnum } from "@src/lib/types";
import { supportedLocales } from "src/lib/constants";

const locale = Astro.currentLocale;
const t = getTranslations(locale);

const pageTitle = Astro.props.pageTitle as string | undefined;
const metaDescription = Astro.props.metaDescription as string | undefined;
const ogTitle = Astro.props.ogTitle as string | undefined;
const ogDescription = Astro.props.ogDescription as string | undefined;
const ogUrlProp = Astro.props.ogUrl as string | undefined;

const site = `${Astro.site ?? "https://dexwalppoz.com"}`;
const siteBase = site.replace(/\/$/, "");
const defaultLocale = AppLangEnum.PL;

// Astro i18n routes:
// - default locale is *not* prefixed (`prefixDefaultLocale: false`)
// - other locales are prefixed (`/en/...`, `/cs/...`, ...)
const getPathWithoutLocalePrefix = (pathname: string) => {
  const parts = pathname.split("/");
  const maybeLocale = parts[1];
  const hasLocalePrefix = supportedLocales.includes(maybeLocale as AppLangEnum);
  const strippedParts = hasLocalePrefix ? parts.slice(2) : parts.slice(1);
  const strippedPath = `/${strippedParts.join("/")}`;
  return strippedPath === "" ? "/" : strippedPath;
};

const pathWithoutLocale = getPathWithoutLocalePrefix(Astro.url.pathname);
const isProductPage = pathWithoutLocale.startsWith("/products/");
const productHreflangByLocale = Astro.props.productHreflangByLocale;

const buildUrlForLocale = (targetLocale: AppLangEnum) => {
  // `pathWithoutLocale` already starts with `/`.
  if (targetLocale === defaultLocale)
    return new URL(pathWithoutLocale, siteBase).toString();
  // Ensure homepage stays `/en/` (not `/en//`).
  if (pathWithoutLocale === "/")
    return new URL(`/${targetLocale}/`, siteBase).toString();
  return new URL(`/${targetLocale}${pathWithoutLocale}`, siteBase).toString();
};

const sanitizeTextForMeta = (value: string) =>
  value
    // Remove any HTML tags that may come from CMS-rich text.
    .replace(/<[^>]*>/g, " ")
    // Collapse whitespace.
    .replace(/\s+/g, " ")
    .trim();

const resolvedMetaDescription = sanitizeTextForMeta(
  metaDescription ?? t.meta.description,
);
const resolvedOgTitle = ogTitle ?? pageTitle ?? t.meta.title;
const resolvedOgDescription = ogDescription ?? resolvedMetaDescription;
const resolvedOgUrl =
  ogUrlProp ?? new URL(Astro.url.pathname, siteBase).toString();
const resolvedOgImage = new URL("/og-image.png", siteBase).toString();
---

<head>
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta name="description" content={resolvedMetaDescription} />
  <!-- Multilingual SEO -->
  <!-- Static pages: page-specific hreflang from current path. -->
  <!-- Product pages: hreflang uses per-page product ID mapping passed via Layout. -->
  {
    !isProductPage && (
      <>
        {supportedLocales.map((locale) => (
          <link
            rel="alternate"
            hreflang={locale}
            href={buildUrlForLocale(locale)}
          />
        ))}
        <link
          rel="alternate"
          hreflang="x-default"
          href={buildUrlForLocale(defaultLocale)}
        />
      </>
    )
  }
  {
    isProductPage && productHreflangByLocale && (
      <>
        {supportedLocales.map((locale) => {
          const href = productHreflangByLocale?.[locale];
          if (!href) return null;
          return <link rel="alternate" hreflang={locale} href={href} />;
        })}
        {productHreflangByLocale?.[defaultLocale] && (
          <link
            rel="alternate"
            hreflang="x-default"
            href={productHreflangByLocale[defaultLocale]}
          />
        )}
      </>
    )
  }

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <!-- PWA / Apple -->
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#c92200" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <!-- Open Graph -->
  <meta property="og:title" content={resolvedOgTitle} />
  <meta property="og:description" content={resolvedOgDescription} />
  <meta property="og:url" content={resolvedOgUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:locale" content={locale} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedOgTitle} />
  <meta name="twitter:description" content={resolvedOgDescription} />
  <meta name="twitter:image" content={resolvedOgImage} />
</head>
