---
import ContactUsSection from "@components/ContactUsSection.astro";
import HeroSection from "@components/HomePage/HeroSection.astro";
import ModernToolsSection from "@components/HomePage/ModernToolsSection.astro";
import WhyUsSection from "@components/HomePage/WhyUsSection.astro";
import Layout from "@layouts/Layout.astro";
import ProductSectionWrapper from "@src/components/HomePage/ProductSectionWrapper.astro";

import { getTranslations } from "@src/locale/getTranslations";
const locale = Astro.currentLocale;
const t = getTranslations(locale);
const pageTitle = t.homepage.pageTitle;
const metaDescription = t.homepage.heroContent ?? t.homepage.hero?.text ?? t.meta.description;
---

<Layout pageTitle={pageTitle} metaDescription={metaDescription} language="pl">
  <HeroSection />

  <ProductSectionWrapper />

  <WhyUsSection />
  <ContactUsSection />
  <ModernToolsSection />
</Layout>
