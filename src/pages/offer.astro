---
import ContactUsSection from '@components/ContactUsSection.astro';
import Layout from '@layouts/Layout.astro';
import HeaderSection from '@src/components/OfferPage/HeaderSection.astro';
import ProductsWrapper from '@src/components/OfferPage/ProductsWrapper.astro';

import { getTranslations } from '@src/locale/getTranslations';
const locale = Astro.currentLocale;
const t = getTranslations(locale);
const pageTitle = t.offerPage.pageTitle;
const metaDescription = `${t.offerPage.pageHeading}. ${[t.offerPage.brackets, t.offerPage.platforms, t.offerPage.other].filter(Boolean).join(", ")}.`;
---

<Layout pageTitle={pageTitle} metaDescription={metaDescription}>
  <HeaderSection />

  <ProductsWrapper />

  <ContactUsSection classes="sectionBreak" />
</Layout>
